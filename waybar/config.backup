{
    "layer": "top", // Waybar at top layer
    "position": "top", // Waybar position (top|bottom|left|right)
    "height": 20, // Waybar height (to be removed for auto height)
    "spacing": 4, // Gaps between modules (4px)
    "fixed-center": true,
    
    // Choose the order of the modules
    "modules-left": ["custom/menu", "hyprland/workspaces", "hyprland/window"],
    // "modules-center": [],
    "modules-right": ["custom/updates", "network", "pulseaudio", "backlight", "battery","cpu", "memory", "clock", "tray", "custom/power"],
    
    // Modules configuration
    "hyprland/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "on-scroll-up": "hyprctl dispatch workspace e+1",
		"on-scroll-down": "hyprctl dispatch workspace e-1",
        "on-click": "activate",
        "format": "{name}:{icon}",
        "format-icons": {
             "1": "яЙй",
             "2": "яАГ",
             "3": "яДб",
             "4": "яКЦ",
             "5": "яАБ",
             "6": "яБ╡",
             "7": "яЕ╝",
             "urgent": "яБк",
             "focused": "яЖТ",
             "default": "яДС"
         }
     },
    
    "disk": {
		"interval": 30,
		"format": "{percentage_used}% <span color=\"#C778DD\">яЯЙ</span>",
		"path": "/"
	},
	
   "mpd": {
        "format": "{title} - {artist} яАБ",
        "format-disconnected": "Disconnected",
        "format-stopped": "Stopped",
        "max-length": 50,
        "on-click": "~/.config/rofi/bin/music",
        "on-click-right": "alacritty -e ncmpcpp"
    },
    
    "tray": {
        // "icon-size": 21,
        "spacing": 10
    },
    
    "clock": {
        // "timezone": "Europe/Berlin",
        "format": "<span color=\"#FFFFFF\">яАЧ</span> {:%H:%M яБ│ %d/%m/%Y}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><big>{calendar}</big></tt>",
        "on-click": "exec wezterm start -e calcure"
        //"format-alt": "{:%d/%m/%Y} <span color=\"#FFFFFF\">яБ│</span>"
    },
           
    "cpu": {
        "format": "{usage}% <span color=\"#EFCA84\">яЛЫ</span>",
        "tooltip": false
    },
    
    "memory": {
        "format": "{}% <span color=\"#62AEEF\">яГЙ</span>"
    },
    
    "backlight": {
        // "device": "acpi_video1",
        "format": "{icon} {percent}%",
        "format-icons": ["юОН", "юПУ", "юПС", "юПП", "юПО", "юПН", "юПК", "юПИ", "юОЫ"]
    },
    
    "battery": {
        "states": {
            // "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "<span color=\"#FFFFFF\">{icon}</span>  {capacity}%",
        "format-charging": "<span color=\"#FF0000\">яЧз</span> {capacity}%",
        "format-plugged": "<span color=\"#FF0000\">юмн</span> {capacity}%",
        "format-alt": "<span color=\"#FF0000\">{icon}</span> {time}",
        // "format-good": "", // An empty format will hide the module
        // "format-full": "",
        "format-icons": ["яЙД", "яЙГ", "яЙВ", "яЙБ", "яЙА"]
    },
    
    "network": {       
        "format-wifi": "<span color=\"#FFFFFF\">яжб</span> {essid} ({signalStrength}%)",
        "format-ethernet": "{ipaddr}/{cidr} <span color=\"#FFFFFF\">яЮЦ</span>",
        "tooltip-format": "{ifname} via {gwaddr} <span color=\"#FFFFFF\">яЮЦ</span>",
        "format-linked": "{ifname} (No IP) <span color=\"#FFFFFF\">яЮЦ</span>",
        "format-disconnected": "Disconnected яжН",
        //"format-alt": "{ifname}: {ipaddr}/{cidr}"
        "on-click": "~/.config/rofi/bin/network_menu",
        "on-click-right": "nm-connection-editor"
    },
    

    "custom/cycle_wall":{
    "format":"яА╛ ",
    "on-click": "~/.config/hypr/bin/changeWallpaper",
    "tooltip-format": "Change wallpaper",
	},
    
    "custom/menu": {
    "format": " <span color=\"#FFFFFF\">яМГ</span> ",
    "tooltip": false,
    "on-click": "pkill rofi || ~/.config/rofi/bin/launcher",
	},
    
    "custom/power": {
    "format": " <span color=\"#FFFFFF\">тП╗</span> ",
    "tooltip": false,
    "on-click": "pkill rofi || ~/.config/rofi/bin/powermenu",
	},

   "custom/filemanager": {
        "format": " яБ╝ ",
        "interval": "once",
        "on-click": "exec 'Thunar'",
    },

  "custom/libre": {
        "format": " яБД ",
        "interval": "once",
        "on-click": "exec libreoffice",
  },

    "custom/browser": {
        "format": " яЙй ",
        "interval": "once",
        "on-click": "exec 'firefox'",
    },

	"custom/scratchpad_indicator": {
        "format": " яЛТ ",
        "on-click": "exec scratchpad -g",
        "tooltip": true,
        "show-empty": false,
    },
  
    "custom/updates": {
        "format": "{}",
        "exec": "~/.config/hypr/waybar/scripts/update-sys",
        "on-click": "~/.config/hypr/waybar/scripts/update-sys update",
        "interval": 30,
        "tooltip": true
    },

    "wlr/taskbar": {
        "format": "{name}",
        "icon-size": 17,
        "all-outputs": true,
        "tooltip-format": "{title}",
        "on-click": "activate",
        "on-click-middle": "close",
        "ignore-list": [
            "rofi"
         ]
    },
    
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "яБо",
            "deactivated": "<span color=\"#FF0000\">яБ░</span>"
        },
        "tooltip": "true"
    },
    
    "hyprland/language": {
    "format": "{}",
    "format-bn": "bn",
    "format-us": "us",
    "format-en": "us",
    },

    "custom/ibus_layout": {
    "exec": "sleep 0.1s && cat ~/.cache/ibus-layout",
    "interval": 3,
    "tooltip": false,
    },
    
    "hyprland/window": {
		"format": " {}",
		"max-length": 150,
		"separate-outputs": true
     },
}
